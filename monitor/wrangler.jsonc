{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sosumi-monitor",
  "main": "src/index.ts",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "triggers": {
    "crons": ["*/5 * * * *"]
  },
  "send_email": [
    {
      "name": "EMAIL_ALERT",
      "destination_address": "alerts@sosumi.ai"
    }
  ]
}
